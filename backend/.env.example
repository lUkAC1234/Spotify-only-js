SECRET_KEY=
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1
SITE_URL=http://localhost:8000
APP_VERSION=0.1.0

NAME=spotify
USER=postgres
PASSWORD=
HOST=localhost
PORT=5432

JAMENDO_CLIENT_ID=
AUDIUS_DISCOVERY_HOST=

# Optional. UNOFFICIAL Yandex Music provider — personal/educational use only,
# violates Yandex Music ToS. Leave empty to disable; provider stays dormant.
# Get a token via: https://oauth.yandex.ru/authorize?response_type=token&client_id=23cabbbdc6cd418abb4b39c32c41195d
YANDEX_MUSIC_TOKEN=

# Optional. Default upstream source for discovery endpoints when no ?source= is given.
# Discovery endpoints aggregate across all configured providers when this is empty.
# Valid values: jamendo, audius, yandex (yandex requires YANDEX_MUSIC_TOKEN).
DEFAULT_CATALOG_SOURCE=

CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
CSRF_TRUSTED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

DEFAULT_FROM_EMAIL=no-reply@spotify.local
